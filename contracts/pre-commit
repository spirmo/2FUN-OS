#!/bin/bash

echo "🔍 2FUN Contract Check Running..."

CHANGED_FILES=$(git diff --cached --name-only)

for file in $CHANGED_FILES; do
  if [[ $file == modules/* ]]; then
    MODULE=$(echo $file | cut -d'/' -f2)

    if [ ! -d "../../contracts/api/$MODULE" ] && \
       [ ! -d "../../contracts/events/$MODULE" ] && \
       [ ! -d "../../contracts/schemas/$MODULE" ]; then

      echo ""
      echo "❌ CONTRACT VIOLATION DETECTED"
      echo "Module: $MODULE"
      echo "Reason: No contract found in /contracts"
      echo ""
      echo "Required:"
      echo "- contracts/api/$MODULE"
      echo "- contracts/events/$MODULE"
      echo "- contracts/schemas/$MODULE"
      echo ""

      exit 1
    fi
  fi
done

echo "✅ Contract validation passed"
exit 0
